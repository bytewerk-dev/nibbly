# Nibbly CMS - .htaccess
# Apache mod_rewrite required
#
# All routing logic lives in route.php — this file is language-agnostic
# and never needs to be edited when changing SITE_LANG_DEFAULT.

RewriteEngine On

# ============================================
# Security - Protect sensitive files
# ============================================

# Deny access to config files
<FilesMatch "^(config\.php|smtp-config\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to JSON content files, backups, and trash directories
RewriteRule ^content/ - [F,L]
RewriteRule ^backups/ - [F,L]
RewriteRule ^(.*/-trash/) - [F,L]

# ============================================
# Static files & directories
# ============================================

# Serve existing files directly (CSS, JS, images, fonts, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Serve directories that have an index.php (e.g. /admin/)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.php -f
RewriteRule ^ - [L]

# Clean URLs: if slug.php exists as a file, serve it directly
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# ============================================
# Front Controller
# ============================================

# Everything else goes to route.php (language routing, news, JSON pages)
RewriteRule ^(.*)$ route.php [L,QSA]

# ============================================
# Error Pages
# ============================================
ErrorDocument 404 /404.php
